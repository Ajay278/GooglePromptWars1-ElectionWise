# ElectionWise Environment Configuration
# Copy this file to .env and fill in your values for local development.
# NOTE: When deploying to Google Cloud Run, these are managed by Cloud Run directly.

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/service-account.json" # Only needed if not using gcloud auth application-default login

# Server Configuration
PORT=3001
NODE_ENV="development"
